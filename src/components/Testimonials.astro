---
import TestimonialCard from './TestimonialCard.astro';

interface Props {
  lang: 'es' | 'en' | 'zh';
  t: (key: string) => string;
}

const { lang, t } = Astro.props;

const testimonials = [
  {
    name: t('testimonials.1.name'),
    location: t('testimonials.1.location'),
    text: t('testimonials.1.text'),
    initials: 'MS',
    image: 'https://firebasestorage.googleapis.com/v0/b/aconcagua-co.firebasestorage.app/o/3f7b0578-4eeb-4f82-b769-1a94afd20811.jpeg?alt=media&token=4bd21417-6402-45b1-a358-56c292f2efc2',
  },
  {
    name: t('testimonials.2.name'),
    location: t('testimonials.2.location'),
    text: t('testimonials.2.text'),
    initials: 'CC',
    image: 'https://firebasestorage.googleapis.com/v0/b/aconcagua-co.firebasestorage.app/o/23c5ad1a-f6a9-4bd8-b428-6e1673f980fd.jpeg?alt=media&token=40f42908-ec5d-4568-b86b-f0b69f338fd9',
  },
];
---

<section id="testimonios" class="testimonials section-pad">
  <div class="container">
    <div class="testimonials-header reveal">
      <p class="tag">{t('testimonials.tag')}</p>
      <h2>{t('testimonials.title')}</h2>
    </div>

    <div class="testimonials-grid">
      {testimonials.map((t_item, i) => (
        <TestimonialCard
          name={t_item.name}
          location={t_item.location}
          text={t_item.text}
          initials={t_item.initials}
          image={t_item.image}
          delay={i * 0.12}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: var(--section-testimonials-bg);
  }

  .testimonials-header {
    text-align: center;
    max-width: 560px;
    margin-inline: auto;
    margin-bottom: clamp(40px, 5vw, 56px);
  }

  .testimonials-header h2 {
    font-size: var(--fs-h1);
    color: var(--text-primary);
    margin-top: 4px;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--gap-grid);
    align-items: start;
    max-width: 900px;
    margin-inline: auto;
  }

  @media (max-width: 640px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
    }
  }
</style>
