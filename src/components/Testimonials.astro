---
import TestimonialCard from './TestimonialCard.astro';

interface Props {
  lang: 'es' | 'en' | 'zh';
  t: (key: string) => string;
}

const { lang, t } = Astro.props;

const testimonials = [
  {
    name: t('testimonials.1.name'),
    location: t('testimonials.1.location'),
    text: t('testimonials.1.text'),
    initials: 'JC',
    photo: 'https://firebasestorage.googleapis.com/v0/b/aconcagua-co.firebasestorage.app/o/Julio.jpg?alt=media&token=8d3d05cc-f1df-4299-b749-c718666d9085',
    photoAlt: t('testimonials.1.name'),
  },
  {
    name: t('testimonials.2.name'),
    location: t('testimonials.2.location'),
    text: t('testimonials.2.text'),
    initials: 'MS',
    photo: 'https://firebasestorage.googleapis.com/v0/b/aconcagua-co.firebasestorage.app/o/Marcelo.jpg?alt=media&token=3fd16581-216a-4b34-8cd0-753da0527289',
    photoAlt: t('testimonials.2.name'),
  },
  {
    name: t('testimonials.3.name'),
    location: t('testimonials.3.location'),
    text: t('testimonials.3.text'),
    initials: 'CC',
    photo: 'https://firebasestorage.googleapis.com/v0/b/aconcagua-co.firebasestorage.app/o/Cata.jpg?alt=media&token=51846657-3928-469f-8b2d-4e61e89db66f',
    photoAlt: t('testimonials.3.name'),
  },
  {
    name: t('testimonials.4.name'),
    location: t('testimonials.4.location'),
    text: t('testimonials.4.text'),
    initials: 'RP',
    photo: undefined,
    photoAlt: t('testimonials.4.name'),
  },
];

const prevLabel = lang === 'zh' ? '上一条' : lang === 'en' ? 'Previous testimonial' : 'Testimonio anterior';
const nextLabel = lang === 'zh' ? '下一条' : lang === 'en' ? 'Next testimonial' : 'Testimonio siguiente';
const carouselLabel = lang === 'zh' ? '客户评价轮播' : lang === 'en' ? 'Client testimonials carousel' : 'Carrusel de testimonios';
---

<section id="testimonios" class="testimonials section-pad">
  <div class="container">
    <div class="testimonials-header reveal">
      <p class="tag">{t('testimonials.tag')}</p>
      <h2>{t('testimonials.title')}</h2>
    </div>

    <div class="carousel" role="region" aria-label={carouselLabel}>
      <div class="carousel-wrapper" aria-live="polite">
        <div class="carousel-track" id="testimonials-track">
          {testimonials.map((item, i) => (
            <div class="carousel-slide" role="group" aria-label={`${i + 1} / ${testimonials.length}`}>
              <TestimonialCard
                name={item.name}
                location={item.location}
                text={item.text}
                initials={item.initials}
                photo={item.photo}
                photoAlt={item.photoAlt}
                delay={0}
              />
            </div>
          ))}
        </div>
      </div>

      <div class="carousel-nav">
        <button
          class="carousel-btn carousel-btn--prev"
          id="testimonials-prev"
          aria-label={prevLabel}
          type="button"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>

        <div class="carousel-dots" id="testimonials-dots" role="tablist" aria-label={carouselLabel}>
          {testimonials.map((_, i) => (
            <button
              class={`dot${i === 0 ? ' dot--active' : ''}`}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-label={`${i + 1}`}
              data-index={i}
              type="button"
            />
          ))}
        </div>

        <button
          class="carousel-btn carousel-btn--next"
          id="testimonials-next"
          aria-label={nextLabel}
          type="button"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: var(--section-testimonials-bg);
  }

  .testimonials-header {
    text-align: center;
    max-width: 560px;
    margin-inline: auto;
    margin-bottom: clamp(40px, 5vw, 56px);
  }

  .testimonials-header h2 {
    font-size: var(--fs-h1);
    color: var(--text-primary);
    margin-top: 4px;
  }

  /* ─── Carousel ─────────────────────────────────────────── */

  .carousel {
    max-width: 680px;
    margin-inline: auto;
  }

  .carousel-wrapper {
    overflow: hidden;
    border-radius: var(--radius-lg);
  }

  .carousel-track {
    display: flex;
    will-change: transform;
  }

  @media (prefers-reduced-motion: no-preference) {
    .carousel-track {
      transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    }
  }

  .carousel-slide {
    flex: 0 0 100%;
    min-width: 0;
  }

  /* ─── Navigation ────────────────────────────────────────── */

  .carousel-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-top: 28px;
  }

  .carousel-btn {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    background: transparent;
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
    flex-shrink: 0;
  }

  .carousel-btn:hover {
    background: var(--accent);
    color: var(--white);
  }

  .carousel-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .carousel-btn:hover {
      transform: scale(1.08);
    }
  }

  /* ─── Dots ──────────────────────────────────────────────── */

  .carousel-dots {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .dot:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .dot--active {
    background: var(--accent);
    transform: scale(1.25);
  }
</style>

<script>
  (function () {
    const track = document.getElementById('testimonials-track') as HTMLElement | null;
    const prevBtn = document.getElementById('testimonials-prev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('testimonials-next') as HTMLButtonElement | null;
    const dotsContainer = document.getElementById('testimonials-dots') as HTMLElement | null;

    if (!track || !prevBtn || !nextBtn || !dotsContainer) return;

    const slides = track.querySelectorAll<HTMLElement>('.carousel-slide');
    const dots = dotsContainer.querySelectorAll<HTMLButtonElement>('.dot');
    const total = slides.length;
    let current = 0;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function goTo(index: number): void {
      current = ((index % total) + total) % total;
      if (prefersReduced) {
        track!.style.transition = 'none';
      }
      track!.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((dot, i) => {
        const active = i === current;
        dot.classList.toggle('dot--active', active);
        dot.setAttribute('aria-selected', active ? 'true' : 'false');
      });
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => goTo(i));
    });

    // Touch / swipe support
    let touchStartX = 0;
    let touchEndX = 0;

    track.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.changedTouches[0].clientX;
    }, { passive: true });

    track.addEventListener('touchend', (e: TouchEvent) => {
      touchEndX = e.changedTouches[0].clientX;
      const delta = touchStartX - touchEndX;
      if (Math.abs(delta) >= 50) {
        goTo(delta > 0 ? current + 1 : current - 1);
      }
    }, { passive: true });
  })();
</script>
